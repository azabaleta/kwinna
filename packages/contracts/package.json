{
  "name": "@kwinna/contracts",
  "version": "0.0.1",
  "private": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs --dts --out-dir dist --clean",
    "dev": "tsup src/index.ts --format cjs --dts --out-dir dist --watch",
    "lint": "eslint .",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.4.0"
  }
}
