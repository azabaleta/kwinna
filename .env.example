# ─── Backend ──────────────────────────────────────────────────────────────────
PORT=3001
JWT_SECRET=kwinna-dev-secret-change-in-prod
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kwinna

# URL pública de la API (usada por MP para los webhooks — debe ser accesible desde internet)
API_URL=http://localhost:3001

# URL pública del frontend (usada en back_urls de MP)
APP_URL=http://localhost:3000

# ─── MercadoPago ──────────────────────────────────────────────────────────────
# Obtener en https://www.mercadopago.com.ar/settings/account/credentials
# Usar TEST_ACCESS_TOKEN para sandbox, PROD_ACCESS_TOKEN para producción
MP_ACCESS_TOKEN=TEST-xxxxxxxxxxxxxxxxxxxx

# Secret para verificar la firma de los webhooks de MP (Webhooks v2)
# Configurar en https://www.mercadopago.com.ar/developers/panel/app → Webhooks
MP_WEBHOOK_SECRET=

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001

# true  → activa mocks MSW (desarrollo sin API/BD corriendo — recomendado por defecto)
# false → usa la API real en http://localhost:3001
NEXT_PUBLIC_USE_MOCKS=true
