# ══════════════════════════════════════════════════════════════════════════════
# Kwinna — Variables de Entorno
# Copiar a .env (local) o cargar en el panel de Railway / Render / Vercel.
# Las variables marcadas con (*) son OBLIGATORIAS en producción.
# ══════════════════════════════════════════════════════════════════════════════

# ─── Backend (apps/api) ───────────────────────────────────────────────────────

# Puerto en que escucha Express.
# Railway/Render lo inyectan automáticamente — no hace falta setearlo en PaaS.
PORT=3001

# (*) Secret para firmar JWT.  Mínimo 32 caracteres aleatorios en producción.
# Generar con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# ─── Usuario Admin ────────────────────────────────────────────────────────────
# (*) Datos del administrador principal del sistema.
# ADMIN_PASSWORD_HASH se genera con:
#   node -e "require('bcryptjs').hash('TuContraseña', 12).then(console.log)"
# Luego correr: pnpm --filter @kwinna/api db:seed-admin
ADMIN_EMAIL=jjulieta.c981@gmail.com
ADMIN_NAME=Juli
ADMIN_PASSWORD_HASH=

# (*) Cadena de conexión a PostgreSQL.
# Render:  postgresql://user:pass@host/db?sslmode=require
# Railway: lo provee automáticamente como DATABASE_URL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kwinna

# (*) URL pública del propio backend.
# Usada por MercadoPago para los webhooks — debe ser accesible desde internet.
# Ejemplo Railway: https://kwinna-api.up.railway.app
API_URL=http://localhost:3001

# (*) URL pública del frontend.
# Usada en back_urls de MercadoPago (redirección post-pago).
# Ejemplo Vercel: https://kwinna.vercel.app
APP_URL=http://localhost:3000

# (*) Orígenes CORS permitidos (separados por coma, sin espacios al final).
# El backend rechaza cualquier origen que no esté en esta lista.
# Ejemplo producción: CORS_ORIGIN=https://kwinna.vercel.app,https://kwinna.com.ar
# Para desarrollo local no es necesario modificar este valor.
CORS_ORIGIN=http://localhost:3000

# ─── MercadoPago ──────────────────────────────────────────────────────────────
# Credenciales en: https://www.mercadopago.com.ar/settings/account/credentials
# Usar TEST_ACCESS_TOKEN para sandbox, PROD_ACCESS_TOKEN para producción.
# (*) en producción
MP_ACCESS_TOKEN=TEST-xxxxxxxxxxxxxxxxxxxx

# Secret para verificar la firma HMAC-SHA256 de los webhooks de MP (v2).
# Configurar en: https://www.mercadopago.com.ar/developers/panel/app → Webhooks
# (*) en producción
MP_WEBHOOK_SECRET=

# ─── Frontend (apps/web — Vercel) ─────────────────────────────────────────────

# (*) URL pública del backend — usada por el navegador para llamadas a la API.
# En Vercel: Settings → Environment Variables → NEXT_PUBLIC_API_URL
# Ejemplo: https://kwinna-api.up.railway.app
NEXT_PUBLIC_API_URL=http://localhost:3001

# URL interna/privada del backend — usada SOLO en el servidor de Next.js
# (Server Components, sitemap, generateMetadata).
# Permite apuntar a una red interna en PaaS sin exponer credenciales al cliente.
# Si no se setea, se usa NEXT_PUBLIC_API_URL como fallback.
# Ejemplo Railway (same-project): http://api.railway.internal:3001
API_URL=http://localhost:3001

# (*) URL pública del frontend — usada para metadataBase, sitemap y robots.
# Ejemplo: https://kwinna.vercel.app  o  https://kwinna.com.ar
NEXT_PUBLIC_APP_URL=http://localhost:3000

# true  → activa mocks MSW (desarrollo sin API/BD corriendo — recomendado)
# false → usa la API real apuntada por NEXT_PUBLIC_API_URL
# IMPORTANTE: siempre false en producción
NEXT_PUBLIC_USE_MOCKS=false

# ─── Cloudinary (apps/web — uploads de imágenes) ──────────────────────────────
# Credenciales en: https://cloudinary.com/console
# El upload preset debe ser de tipo "Unsigned" para que el frontend suba directo.
# (*) Obligatorio para que CreateProductDialog funcione en producción.
#
# Pasos:
#   1. Ir a Settings → Upload → Upload presets → Add upload preset
#   2. Signing mode: Unsigned
#   3. Copiar el nombre del preset y el Cloud name de la pantalla de Dashboard
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=tu_cloud_name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=tu_upload_preset
